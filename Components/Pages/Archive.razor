@page "/archive"
@inject IItemService ItemService

<PageTitle>Archive · Nook</PageTitle>

<div class="d-flex align-center mb-4 flex-wrap gap-2">
    <MudText Typo="Typo.h4">Archive</MudText>
    <MudSpacer />
    <MudTextField T="string" Value="_search" ValueChanged="OnSearch" Label="Search archived"
                  Immediate="true" Clearable="true" DebounceInterval="300" Margin="Margin.Dense"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Style="max-width:280px;" />
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_items.Count == 0)
{
    <MudAlert Severity="Severity.Info">No archived items.</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var item in _items)
        {
            <MudItem xs="12" sm="6" md="4">
                <ItemCard Item="item" OnChanged="ReloadAsync" />
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<Item> _items = new();
    private string? _search;
    private bool _loading = true;

    protected override Task OnInitializedAsync() => ReloadAsync();

    private Task OnSearch(string? value)
    {
        _search = value;
        return ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _items = await ItemService.GetItemsAsync(new ItemFilter
        {
            ShowArchived = true,
            SearchText = _search
        });
        _loading = false;
    }
}
