@page "/reminders"
@inject IItemService ItemService

<PageTitle>Reminders · Nook</PageTitle>

<div class="d-flex align-center mb-4">
    <MudText Typo="Typo.h4">Reminders</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               Href="/items/new?type=Reminder">New reminder</MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudPaper Elevation="1" Class="pa-4 mb-4">
        <div class="d-flex align-center mb-2">
            <MudIcon Icon="@Icons.Material.Filled.NotificationImportant" Color="Color.Error" Class="mr-2" />
            <MudText Typo="Typo.h6">Overdue</MudText>
        </div>
        @RenderReminderList(_overdue, "Nothing overdue.", Color.Error)
    </MudPaper>

    <MudPaper Elevation="1" Class="pa-4">
        <div class="d-flex align-center mb-2">
            <MudIcon Icon="@Icons.Material.Filled.Alarm" Color="Color.Primary" Class="mr-2" />
            <MudText Typo="Typo.h6">Upcoming</MudText>
        </div>
        @RenderReminderList(_upcoming, "No upcoming reminders.", Color.Primary)
    </MudPaper>
}

@code {
    private List<Item> _overdue = new();
    private List<Item> _upcoming = new();
    private bool _loading = true;

    protected override Task OnInitializedAsync() => ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _overdue = await ItemService.GetOverdueRemindersAsync();
        _upcoming = await ItemService.GetUpcomingRemindersAsync();
        _loading = false;
    }

    private RenderFragment RenderReminderList(List<Item> items, string emptyText, Color dateColor) => __builder =>
    {
        if (items.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@emptyText</MudText>
        }
        else
        {
            <MudList T="string" Dense="true">
                @foreach (var item in items)
                {
                    <MudListItem T="string">
                        <div class="d-flex align-center gap-3 flex-wrap">
                            <MudLink Href="@($"/items/{item.ItemId}")" Class="flex-grow-1">@item.Title</MudLink>
                            <MudText Typo="Typo.caption" Color="@dateColor">
                                @item.ReminderDate?.ToLocalTime().ToString("g")
                            </MudText>
                            <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Check"
                                       OnClick="@(() => Complete(item.ItemId))">Complete</MudButton>
                        </div>
                    </MudListItem>
                }
            </MudList>
        }
    };

    private async Task Complete(int id)
    {
        await ItemService.CompleteAsync(id);
        await ReloadAsync();
    }
}
