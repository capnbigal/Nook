@page "/todos"
@inject IItemService ItemService

<PageTitle>Todos · Nook</PageTitle>

<div class="d-flex align-center mb-4 flex-wrap gap-2">
    <MudText Typo="Typo.h4">Todos</MudText>
    <MudSpacer />
    <MudSwitch T="bool" Value="_showCompleted" Label="Show completed" Color="Color.Primary"
               ValueChanged="OnToggleShowCompleted" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               Href="/items/new?type=Todo">New todo</MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_todos.Count == 0)
{
    <MudAlert Severity="Severity.Info">No todos. Create one to get started.</MudAlert>
}
else
{
    <MudPaper Elevation="1" Class="pa-2">
        <MudList T="string">
            @foreach (var todo in _todos)
            {
                <MudListItem T="string">
                    <div class="d-flex align-center gap-3 flex-wrap">
                        <MudCheckBox T="bool" Value="@(todo.Status == ItemStatus.Done)"
                                     ValueChanged="@(v => ToggleComplete(todo, v))" Color="Color.Primary" />
                        <MudLink Href="@($"/items/{todo.ItemId}")" Class="flex-grow-1"
                                 Style="@(todo.Status == ItemStatus.Done ? "text-decoration:line-through;opacity:.6;" : "")">
                            @todo.Title
                        </MudLink>
                        <MudSelect T="Priority?" Value="todo.Priority" Label="Priority" Clearable="true"
                                   Dense="true" Margin="Margin.Dense" Style="max-width:130px;"
                                   ValueChanged="@(p => SetPriority(todo, p))">
                            @foreach (var p in Enum.GetValues<Priority>())
                            {
                                <MudSelectItem T="Priority?" Value="@((Priority?)p)">@p</MudSelectItem>
                            }
                        </MudSelect>
                        <MudDatePicker Date="todo.DueDate" Label="Due" Clearable="true"
                                       Margin="Margin.Dense" Style="max-width:160px;"
                                       DateChanged="@(d => SetDue(todo, d))" />
                    </div>
                </MudListItem>
            }
        </MudList>
    </MudPaper>
}

@code {
    private List<Item> _todos = new();
    private bool _showCompleted;
    private bool _loading = true;

    protected override Task OnInitializedAsync() => ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _todos = await ItemService.GetTodosAsync(_showCompleted);
        _loading = false;
    }

    private Task OnToggleShowCompleted(bool value)
    {
        _showCompleted = value;
        return ReloadAsync();
    }

    private async Task ToggleComplete(Item todo, bool isDone)
    {
        if (isDone)
        {
            await ItemService.CompleteAsync(todo.ItemId);
        }
        else
        {
            await ItemService.ReopenAsync(todo.ItemId);
        }
        await ReloadAsync();
    }

    private async Task SetPriority(Item todo, Priority? priority)
    {
        todo.Priority = priority;
        await ItemService.UpdateAsync(todo);
        await ReloadAsync();
    }

    private async Task SetDue(Item todo, DateTime? due)
    {
        todo.DueDate = due;
        await ItemService.UpdateAsync(todo);
        await ReloadAsync();
    }
}
