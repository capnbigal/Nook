@page "/timeline"
@inject IActivityService ActivityService
@inject IEventService EventService
@inject ICurrentUser CurrentUser

<PageTitle>Timeline · Nook</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Timeline</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
    A chronological feed of changes across your graph. Life events you log appear on the
    <MudLink Href="/events">Events</MudLink> page.
</MudText>

@if (_rows is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_rows.Count == 0)
{
    <MudAlert Severity="Severity.Info">Nothing yet. Start capturing.</MudAlert>
}
else
{
    <MudText Typo="Typo.caption" Class="mud-text-secondary">
        Showing the most recent @_rows.Count change(s)@(_hasMore ? " — load more below" : "").
    </MudText>
    <MudTimeline TimelinePosition="TimelinePosition.Start" Class="mt-2">
        @foreach (var day in _rows.GroupBy(r => DateOnly.FromDateTime(r.Timestamp.ToLocalTime())).OrderByDescending(g => g.Key))
        {
            <MudTimelineItem Color="Color.Primary" Icon="@Icons.Material.Filled.Event">
                <MudText Typo="Typo.subtitle2">@day.Key.ToString("dddd, MMM d")</MudText>
                @foreach (var ev in day.OrderByDescending(e => e.Timestamp))
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        @ev.Type —
                        @if (ev.NodeId is int nid)
                        {
                            <MudLink Href="@($"/nodes/{nid}")">@ev.ItemTitle</MudLink>
                        }
                        else
                        {
                            @ev.ItemTitle
                        }
                        @(ev.Detail is null ? "" : $" ({ev.Detail})")
                    </MudText>
                }
            </MudTimelineItem>
        }
    </MudTimeline>

    @if (_hasMore)
    {
        <div class="d-flex justify-center mt-3">
            <MudButton Variant="Variant.Outlined" OnClick="LoadMore">Load more</MudButton>
        </div>
    }
}

@code {
    private List<ActivityLog>? _rows;
    private int _limit = 100;
    private bool _hasMore;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        var userId = await CurrentUser.GetRequiredUserIdAsync();
        // Ask for one extra to know whether more history exists (no silent cap).
        var rows = await ActivityService.GetForUserAsync(userId, take: _limit + 1);
        _hasMore = rows.Count > _limit;
        _rows = rows.Take(_limit).ToList();
    }

    private async Task LoadMore()
    {
        _limit += 100;
        await LoadAsync();
    }
}
