@page "/items/new"
@inject IItemService ItemService
@inject ITagService TagService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>New item · Nook</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">New item</MudText>

<MudPaper Class="pa-6" Elevation="1">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <ItemEditor Item="_item" AllTags="_allTags" SelectedTagIds="_selectedTagIds"
                    SubmitLabel="Create" OnValidSubmit="SaveAsync" OnCancel="Cancel" />
    }
</MudPaper>

@code {
    private Item _item = new() { ItemType = ItemType.Note, Status = ItemStatus.Open };
    private List<Tag> _allTags = new();
    private readonly List<int> _selectedTagIds = new();
    private bool _loading = true;

    // Optional ?type=Todo lets other pages open the form pre-set to a type.
    [SupplyParameterFromQuery(Name = "type")] public string? Type { get; set; }

    // Optional ?parentId=5 creates this item as a sub-item of another.
    [SupplyParameterFromQuery(Name = "parentId")] public int? ParentId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _allTags = await TagService.GetAllAsync();
        if (Enum.TryParse<ItemType>(Type, ignoreCase: true, out var type))
        {
            _item.ItemType = type;
        }
        _item.ParentItemId = ParentId;
        _loading = false;
    }

    private async Task SaveAsync()
    {
        await ItemService.CreateAsync(_item, _selectedTagIds);
        Snackbar.Add("Item created", Severity.Success);
        Nav.NavigateTo($"/items/{_item.ItemId}");
    }

    private void Cancel() => Nav.NavigateTo("/items");
}
