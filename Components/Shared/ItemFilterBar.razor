@* Search + filter controls for the items list. Raises OnChanged on any change. *@
<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid Spacing="2">
        <MudItem xs="12" md="4">
            <MudTextField T="string" Value="Filter.SearchText" ValueChanged="OnSearch"
                          Label="Search title, body, URL, tags" Immediate="true" Clearable="true"
                          DebounceInterval="300"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
        </MudItem>
        <MudItem xs="6" md="2">
            <MudSelect T="ItemType?" Value="Filter.ItemType" ValueChanged="OnType" Label="Type"
                       Clearable="true" Dense="true">
                @foreach (var t in Enum.GetValues<ItemType>())
                {
                    <MudSelectItem T="ItemType?" Value="@((ItemType?)t)">@t</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudSelect T="ItemStatus?" Value="Filter.Status" ValueChanged="OnStatus" Label="Status"
                       Clearable="true" Dense="true">
                @foreach (var s in Enum.GetValues<ItemStatus>())
                {
                    <MudSelectItem T="ItemStatus?" Value="@((ItemStatus?)s)">@s</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudSelect T="Priority?" Value="Filter.Priority" ValueChanged="OnPriority" Label="Priority"
                       Clearable="true" Dense="true">
                @foreach (var p in Enum.GetValues<Priority>())
                {
                    <MudSelectItem T="Priority?" Value="@((Priority?)p)">@p</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudSelect T="int?" Value="Filter.TagId" ValueChanged="OnTag" Label="Tag"
                       Clearable="true" Dense="true">
                @foreach (var tag in AllTags)
                {
                    <MudSelectItem T="int?" Value="@((int?)tag.TagId)">@tag.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <MudItem xs="12" Class="d-flex flex-wrap gap-2 align-center">
            <MudChip T="string" Color="Color.Primary" Variant="@FlagVariant(Filter.DueSoon)"
                     OnClick="@(() => ToggleAsync(() => Filter.DueSoon = !Filter.DueSoon))">Due soon</MudChip>
            <MudChip T="string" Color="Color.Error" Variant="@FlagVariant(Filter.Overdue)"
                     OnClick="@(() => ToggleAsync(() => Filter.Overdue = !Filter.Overdue))">Overdue</MudChip>
            <MudChip T="string" Color="Color.Warning" Variant="@FlagVariant(Filter.FavoritesOnly)"
                     OnClick="@(() => ToggleAsync(() => Filter.FavoritesOnly = !Filter.FavoritesOnly))">Favorites</MudChip>
            <MudChip T="string" Color="Color.Info" Variant="@FlagVariant(Filter.PinnedOnly)"
                     OnClick="@(() => ToggleAsync(() => Filter.PinnedOnly = !Filter.PinnedOnly))">Pinned</MudChip>
            <MudSpacer />
            <MudButton StartIcon="@Icons.Material.Filled.FilterAltOff" OnClick="Clear" Variant="Variant.Text">Clear</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    [Parameter, EditorRequired] public ItemFilter Filter { get; set; } = default!;
    [Parameter] public List<Tag> AllTags { get; set; } = new();
    [Parameter] public EventCallback OnChanged { get; set; }

    private static Variant FlagVariant(bool on) => on ? Variant.Filled : Variant.Outlined;

    private Task Changed() => OnChanged.InvokeAsync();

    private async Task OnSearch(string? v) { Filter.SearchText = v; await Changed(); }
    private async Task OnType(ItemType? v) { Filter.ItemType = v; await Changed(); }
    private async Task OnStatus(ItemStatus? v) { Filter.Status = v; await Changed(); }
    private async Task OnPriority(Priority? v) { Filter.Priority = v; await Changed(); }
    private async Task OnTag(int? v) { Filter.TagId = v; await Changed(); }

    private async Task ToggleAsync(Action toggle)
    {
        toggle();
        await Changed();
    }

    private async Task Clear()
    {
        Filter.SearchText = null;
        Filter.ItemType = null;
        Filter.Status = null;
        Filter.Priority = null;
        Filter.TagId = null;
        Filter.DueSoon = false;
        Filter.Overdue = false;
        Filter.FavoritesOnly = false;
        Filter.PinnedOnly = false;
        await Changed();
    }
}
