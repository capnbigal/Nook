@* Create/edit form for a node. *@

<MudForm>
    <MudTextField @bind-Value="Node.Title" Label="Title" Required="true" Immediate="true"
                  MaxLength="300" Class="mb-2" />

    <div class="d-flex gap-3 flex-wrap">
        <MudSelect @bind-Value="Node.Kind" Label="Kind" Dense="true" Style="min-width:180px;">
            @foreach (var kind in NodeUi.AssignableKinds)
            {
                <MudSelectItem Value="kind">@kind</MudSelectItem>
            }
        </MudSelect>
        <MudSelect @bind-Value="Node.State" Label="State" Dense="true" Style="min-width:160px;">
            @foreach (var st in Enum.GetValues<NodeState>())
            {
                <MudSelectItem Value="st">@st</MudSelectItem>
            }
        </MudSelect>
    </div>

    <MudTextField @bind-Value="Node.Url" Label="URL (optional)" Class="mt-2" MaxLength="1000" />

    <MudTextField @bind-Value="Node.Body" Label="Body" Lines="5" Class="mt-2" />

    <div class="mt-3">
        <MudText Typo="Typo.subtitle2" Class="mb-1">Tags</MudText>
        <TagAutocomplete AllTags="AllTags" SelectedTagIds="SelectedTagIds"
                         SelectedTagIdsChanged="OnTagsChanged" />
    </div>

    <div class="d-flex gap-2 mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit"
                   Disabled="@string.IsNullOrWhiteSpace(Node.Title)">@SubmitLabel</MudButton>
        @if (OnCancel.HasDelegate)
        {
            <MudButton Variant="Variant.Text" OnClick="OnCancel">Cancel</MudButton>
        }
    </div>
</MudForm>

@code {
    [Parameter, EditorRequired] public Node Node { get; set; } = default!;
    [Parameter] public List<Tag> AllTags { get; set; } = new();
    [Parameter] public List<int> SelectedTagIds { get; set; } = new();
    [Parameter] public EventCallback<List<int>> SelectedTagIdsChanged { get; set; }
    [Parameter] public string SubmitLabel { get; set; } = "Save";
    [Parameter] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private Task OnTagsChanged(List<int> ids)
    {
        SelectedTagIds = ids;
        return SelectedTagIdsChanged.InvokeAsync(ids);
    }

    private Task Submit() =>
        string.IsNullOrWhiteSpace(Node.Title) ? Task.CompletedTask : OnValidSubmit.InvokeAsync();
}
