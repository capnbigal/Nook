@* A dashboard panel listing a handful of items. Renders as a MudItem (place inside a MudGrid). *@
<MudItem xs="12" md="@Md">
    <MudPaper Class="pa-4" Elevation="1" Style="height:100%;">
        <div class="d-flex align-center mb-2">
            <MudIcon Icon="@Icon" Color="@IconColor" Class="mr-2" />
            <MudText Typo="Typo.h6">@Title</MudText>
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@Items.Count</MudChip>
        </div>

        @if (Items.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@EmptyText</MudText>
        }
        else
        {
            <MudList T="string" Dense="true">
                @foreach (var item in Items)
                {
                    <MudListItem T="string" Href="@($"/items/{item.ItemId}")">
                        <div class="d-flex justify-space-between align-center gap-2">
                            <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@item.Title</span>
                            @if (ShowDate && (item.DueDate ?? item.ReminderDate) is { } when)
                            {
                                <MudText Typo="Typo.caption" Color="@IconColor">@when.ToLocalTime().ToString("MMM d")</MudText>
                            }
                        </div>
                    </MudListItem>
                }
            </MudList>
        }
    </MudPaper>
</MudItem>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Circle;
    [Parameter] public Color IconColor { get; set; } = Color.Default;
    [Parameter] public List<Item> Items { get; set; } = new();
    [Parameter] public string EmptyText { get; set; } = "Nothing here yet.";
    [Parameter] public int Md { get; set; } = 6;
    [Parameter] public bool ShowDate { get; set; }
}
