@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="ToggleDrawer" aria-label="Toggle navigation" />
        <MudText Typo="Typo.h6" Class="ml-2">Nook</MudText>
        <MudSpacer />
        <MudTextField T="string" @bind-Value="_search" Immediate="true"
                      Placeholder="Search…" Variant="Variant.Outlined" Margin="Margin.Dense"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Class="mt-0 mx-2 d-none d-sm-flex" Style="max-width:320px;"
                      OnKeyUp="OnSearchKeyUp" />
        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Inherit"
                       Href="/capture" title="Quick capture" />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="@(() => _isDarkMode = !_isDarkMode)" title="Toggle light/dark" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always"
               Variant="@DrawerVariant.Responsive">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private string? _search;

    // Default theme; customise the palette here later if desired.
    private readonly MudTheme _theme = new();

    [Inject] private NavigationManager Nav { get; set; } = default!;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_search))
        {
            Nav.NavigateTo($"/search?q={Uri.EscapeDataString(_search.Trim())}");
        }
    }
}
