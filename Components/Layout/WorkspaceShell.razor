@inherits LayoutComponentBase
@implements IAsyncDisposable
@using Nook.Components.Workspace
@inject ThemeState Theme
@inject WorkspaceState Workspace
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme" IsDarkMode="Theme.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingValue Value="Workspace">
    <div class="nook-shell">
        <GlobalRail Class="nook-rail" />
        <WorkspaceSidebar Class="nook-sidebar" />
        <div class="nook-main">
            <TopBar Class="nook-topbar" OnOpenPalette="OpenPalette" />
            <main class="nook-content">@Body</main>
        </div>
    </div>
    <CommandPalette Open="_paletteOpen" OpenChanged="v => _paletteOpen = v" Actions="_commands" />
</CascadingValue>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private readonly MudTheme _theme = NookTheme.Build();
    private IJSObjectReference? _shortcutsModule;
    private IJSObjectReference? _themeModule;
    private DotNetObjectReference<WorkspaceShell>? _dotNetRef;
    private bool _paletteOpen;
    private IReadOnlyList<Command> _commands = Array.Empty<Command>(); // Task 20 populates this

    [Inject] private NavigationManager Nav { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await Theme.InitializeAsync();
        await Workspace.InitializeAsync();
        Theme.Changed += OnStateChanged;
        Workspace.Changed += OnStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _shortcutsModule = await JS.InvokeAsync<IJSObjectReference>(
            "import", "./Components/Layout/WorkspaceShell.razor.js");
        _dotNetRef = DotNetObjectReference.Create(this);
        await _shortcutsModule.InvokeVoidAsync("initialize", _dotNetRef);

        // Initial theme paint via the real theme-interop module (Task 12/13 contract);
        // ThemeState.SetAsync drives subsequent toggles.
        _themeModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/theme-interop.js");
        await _themeModule.InvokeVoidAsync("setTheme", Theme.IsDarkMode ? "dark" : null);
    }

    [JSInvokable]
    public Task OnShortcutAsync(string combo)
    {
        switch (combo)
        {
            case "g h":
                Nav.NavigateTo("/today");
                break;
            case "g i":
                Nav.NavigateTo("/inbox");
                break;
            case "mod+k":
                OpenPalette();
                break;
        }
        return InvokeAsync(StateHasChanged);
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void OpenPalette() { _paletteOpen = true; StateHasChanged(); }

    public async ValueTask DisposeAsync()
    {
        Theme.Changed -= OnStateChanged;
        Workspace.Changed -= OnStateChanged;

        if (_shortcutsModule is not null)
        {
            try
            {
                await _shortcutsModule.InvokeVoidAsync("dispose");
                await _shortcutsModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }

        if (_themeModule is not null)
        {
            try { await _themeModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }

        _dotNetRef?.Dispose();
    }
}
