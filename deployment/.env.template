# Copy to `.env` in /opt/nook on the droplet, fill in, then `chmod 600 .env`.
# NEVER COMMIT THE .env FILE.

# --- SQL Server ---------------------------------------------------------------
# MUST be the SAME value as the AWBlazor stack's SA_PASSWORD — Nook connects to
# the existing awblazor-sqlserver container with the sa account.
SA_PASSWORD=USE_THE_SAME_PASSWORD_AS_AWBLAZOR

# --- App image tag (optional) ------------------------------------------------
# GHCR tag to pull. Defaults to "latest". Pin to a <short-sha> for rollbacks.
APP_TAG=latest

# --- Observability (optional) -------------------------------------------------
# Nook is not yet OTel-instrumented; leave blank. Reserved for when it reports
# into the Aspire Dashboard (deployment/OBSERVABILITY.md in the platform repo).
OTLP_ENDPOINT=
OTLP_API_KEY=
